                    $barColor = $mScore >= 70 ? '#22c55e' : ($mScore >= 40 ? '#eab308' : '#ef4444');
                ?>
                <tr>
                    <td><strong><?= $block->escapeHtml($module->getName()) ?></strong></td>
                    <td><?= $block->escapeHtml($module->getVersion() ?: '-') ?></td>
                    <td>
                        <span style="display:flex;align-items:center;gap:8px;">
                            <span class="score-bar" style="width:<?= (int)$mScore ?>px;background:<?= $block->escapeHtmlAttr($barColor) ?>"></span>
                            <?= (int)$mScore ?>
                        </span>
                    </td>
                    <td><span class="badge <?= $module->hasRoutes() ? 'badge-yes' : 'badge-no' ?>"><?= $module->hasRoutes() ? 'Yes' : 'No' ?></span></td>
                    <td><span class="badge <?= $module->hasObservers() ? 'badge-yes' : 'badge-no' ?>"><?= $module->hasObservers() ? 'Yes' : 'No' ?></span></td>
                    <td><span class="badge <?= $module->hasPlugins() ? 'badge-yes' : 'badge-no' ?>"><?= $module->hasPlugins() ? 'Yes' : 'No' ?></span></td>
                    <td><span class="badge <?= $module->hasCron() ? 'badge-yes' : 'badge-no' ?>"><?= $module->hasCron() ? 'Yes' : 'No' ?></span></td>
                    <td><span class="badge <?= $module->hasDatabase() ? 'badge-yes' : 'badge-no' ?>"><?= $module->hasDatabase() ? 'Yes' : 'No' ?></span></td>
